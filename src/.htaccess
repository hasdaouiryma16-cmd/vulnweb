<IfModule mod_headers.c>
    # Utilisation de "always" pour que les headers soient présents même sur les erreurs (404, 500)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; base-uri 'self'; form-action 'self';"
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Cross-Origin-Embedder-Policy "require-corp"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    # On garde le no-store pour la sécurité, tant pis pour le warning ZAP
    Header always set Cache-Control "no-store, no-cache, must-revalidate"
</IfModule>
